# Google Cloud / ADK
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
# ADK deploys directly to Vertex AI Agent Runtime — no separate Agent Builder ID

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=hospital_prices

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# APIs
GOOGLE_MAPS_API_KEY=your-maps-api-key
NPI_REGISTRY_BASE_URL=https://npiregistry.cms.hhs.gov/api/

# Redis (optional, speeds up repeated queries)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
PORT=8080

# MongoDB Atlas Charts (for Insights tab)
# Get these from Atlas → Charts → Embed → Unauthenticated
NEXT_PUBLIC_ATLAS_CHARTS_BASE_URL=https://charts.mongodb.com/charts-YOUR-PROJECT-ID
NEXT_PUBLIC_CHART_PRICE_HISTOGRAM_ID=
NEXT_PUBLIC_CHART_PAYER_BREAKDOWN_ID=
NEXT_PUBLIC_CHART_PRICE_TREND_ID=
